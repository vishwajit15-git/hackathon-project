# ============================================================
#  Smart Crowd Management System — Environment Variables
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/crowd_management

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ML Service (Python FastAPI)
ML_SERVICE_URL=http://localhost:8000

# API Keys (for service-to-service auth — use strong random strings in production)
ML_API_KEY=your_ml_api_key_here
VOICE_API_KEY=your_voice_api_key_here

# Firebase
FIREBASE_API_KEY=your_firebase_web_api_key_here
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# Frontend (CORS)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Crowd Thresholds
STAMPEDE_RISK_THRESHOLD=0.75
CROWD_HIGH_DENSITY_PERCENT=85
CROWD_MEDIUM_DENSITY_PERCENT=65
